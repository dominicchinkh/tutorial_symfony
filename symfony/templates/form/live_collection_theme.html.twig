{#
    Form theme for Symfony UX LiveComponent collection fields (LiveCollectionType).

    What: Overrides how the "add row" and "delete row" buttons are rendered for
    dynamic collections (e.g. Product comments) inside a Live Component form.

    Why: LiveCollectionType wires those buttons to LiveCollectionTrait actions
    (addCollectionItem / removeCollectionItem) so rows update without a full page
    reload. The default markup is plain; this theme applies app styling (DaisyUI
    button classes, a plus icon, translated labels).

    How: ProductForm.html.twig registers this theme with {% form_theme %}. Each
    block below customizes one button type, then delegates to button_widget for
    the actual <button> output.
#}

{% block live_collection_button_add_widget %}

    {# Merge DaisyUI classes; keep any classes already set on the field options. #}
    {% set attr = attr|merge({'class': attr.class|default('btn btn-ghost')}) %}

    {# Label is built manually below, so skip the form type's translation domain. #}
    {% set translation_domain = false %}

    {# Allow raw HTML (the SVG icon) inside the button label. #}
    {% set label_html = true %}

    {%- set label -%}
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
        </svg>
        {{ 'form.collection.button.add.label'|trans({}, 'forms') }}
    {%- endset -%}

    {{ block('button_widget') }}

{% endblock live_collection_button_add_widget %}

{% block live_collection_button_delete_widget %}
    
    {# Per-row remove control; class can still be overridden via button_delete_options in the form type. #}
    {% set attr = attr|merge({'class': attr.class|default('btn btn-outline-danger')}) %}

    {% set translation_domain = false %}

    {{ block('button_widget') }}

{% endblock live_collection_button_delete_widget %}

{# 
   By default the add button is placed after the items (the comments in our case). 
   This moves it before them. 
#}
{%- block live_collection_widget -%}
    {%- if button_add is defined and not button_add.rendered -%}
        {{ form_row(button_add) }}
    {%- endif -%}
    {{ block('form_widget') }}
{%- endblock -%}

{#
    Add a div around each row
#}
{%- block live_collection_entry_row -%}
    <div class="dominic-div">
        {{ block('form_row') }}
        {%- if button_delete is defined and not button_delete.rendered -%}
            {{ form_row(button_delete) }}
        {%- endif -%}
    </div>
{%- endblock -%}
