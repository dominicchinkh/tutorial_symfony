<div {{ attributes }}>
    <input data-model="listName">

    <form data-action="live#action:prevent" data-live-action-param="addTodo">
        <input data-model="newTodo" placeholder="Add a todo">
        <button type="submit">Add</button>
    </form>

    <ul>
        {% for todo in todos %}
            <li>{{ todo }}</li>
        {% endfor %} 
    </ul>

    <twig:TodoFooter count="{{ todos|length }}" />
</div>